# Dependency directories
node_modules/
client/node_modules/
server/node_modules/

# Next.js build output
.next/
client/.next/

# TypeScript build output
dist/
server/dist/

# Local database files
*.db
*.db-journal
server/prisma/dev.db
server/prisma/dev.db-journal

